{
    "id": "sigil-tools",
    "title": "Sigil Tools",
    "description": "Internal tooling module. Contains submodules for roll-model, active-auras, grid-aware-auras, effectmacro, override-settings, and campaign-specific automation.",
    "version": "1.0.16",
    "socket": true,
    "compatibility": {
        "minimum": "13",
        "verified": "14",
        "maximum": "14"
    },
    "authors": [
        {
            "name": "vfez",
            "discord": "fez#1260"
        }
    ],
    "esmodules": ["submodules/roll-model/roll-model.js", "submodules/roll-model/config/config.js", "submodules/effectmacro/scripts/module.mjs"],
    "scripts": [
        "submodules/suppress-warnings/suppress-warnings.js",
        "submodules/override-settings/override.js",
        "submodules/dev-scene-loader/dev-scene-loader.js",
        "submodules/grid-aware-auras/loader.js",
        "submodules/grid-aware-auras/dist/module.js"
    ],
    "styles": ["css/roll-model.css", "submodules/grid-aware-auras/dist/module.css", "submodules/effectmacro/styles/styles.css"],
    "languages": [
        {
            "lang": "en",
            "name": "English",
            "path": "lang/en.json"
        },
        {
            "lang": "en",
            "name": "English",
            "path": "submodules/grid-aware-auras/lang/en.json"
        },
        {
            "lang": "en",
            "name": "English",
            "path": "submodules/effectmacro/lang/en.json"
        },
        {
            "lang": "en",
            "name": "English",
            "path": "submodules/active-auras/lang/en.json"
        }
    ],
    "relationships": {
        "requires": [
            {
                "id": "socketlib",
                "type": "module"
            },
            {
                "id": "lib-wrapper",
                "type": "module",
                "manifest": "https://github.com/ruipin/fvtt-lib-wrapper/releases/latest/download/module.json"
            }
        ],
        "systems": [
            {
                "id": "dnd5e",
                "type": "system",
                "manifest": "https://raw.githubusercontent.com/foundryvtt/dnd5e/master/system.json",
                "compatibility": {
                    "minimum": "5.0.0",
                    "verified": "5.2.5"
                }
            }
        ]
    },
    "url": "https://github.com/vfez1/sigil-tools",
    "manifest": "https://raw.githubusercontent.com/vfez1/sigil-tools/main/module.json",
    "download": "https://github.com/vfez1/sigil-tools/archive/refs/heads/main.zip"
}
