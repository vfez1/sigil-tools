{
    "id": "sigil-tools",
    "title": "Sigil Tools",
    "description": "Internal tooling module. Contains submodules for roll-model, active-auras, grid-aware-auras, effectmacro, override-settings, and campaign-specific automation.",
    "version": "1.0.64",
    "socket": true,
    "compatibility": {
        "minimum": "13",
        "verified": "14",
        "maximum": "14"
    },
    "authors": [
        {
            "name": "vfez",
            "discord": "fez#1260"
        }
    ],
    "esmodules": ["submodules/roll-model/roll-model.js", "submodules/roll-model/config/config.js", "submodules/effectmacro/scripts/module.mjs", "submodules/combat-tracker-dock/scripts/main.js"],
    "scripts": [
        "submodules/suppress-warnings/suppress-warnings.js",
        "submodules/override-settings/override.js",
        "submodules/dev-scene-loader/dev-scene-loader.js"
    ],
    "styles": [
        "submodules/roll-model/roll-model.css",
        "submodules/always-hp/always-hp.css",
        "submodules/character-features/character-features.css",
        "submodules/effectmacro/styles/styles.css",
        "submodules/visual-auras/visual-auras.css",
        "submodules/combat-tracker-dock/styles/module.css"
    ],
    "languages": [
        { "lang": "en", "name": "English", "path": "submodules/roll-model/lang/en.json" },
        { "lang": "en", "name": "English", "path": "submodules/visual-auras/lang/en.json" },
        { "lang": "en", "name": "English", "path": "submodules/character-features/lang/en.json" },
        { "lang": "en", "name": "English", "path": "submodules/chat-archive/lang/en.json" },
        { "lang": "en", "name": "English", "path": "submodules/override-settings/lang/en.json" },
        { "lang": "en", "name": "English", "path": "submodules/suppress-warnings/lang/en.json" },
        { "lang": "en", "name": "English", "path": "submodules/active-auras/lang/en.json" },
        { "lang": "en", "name": "English", "path": "submodules/effectmacro/lang/en.json" },
        { "lang": "en", "name": "English", "path": "submodules/combat-tracker-dock/languages/en.json" }
    ],
    "relationships": {
        "requires": [
            {
                "id": "socketlib",
                "type": "module"
            },
            {
                "id": "lib-wrapper",
                "type": "module",
                "manifest": "https://github.com/ruipin/fvtt-lib-wrapper/releases/latest/download/module.json"
            }
        ],
        "systems": [
            {
                "id": "dnd5e",
                "type": "system",
                "manifest": "https://raw.githubusercontent.com/foundryvtt/dnd5e/master/system.json",
                "compatibility": {
                    "minimum": "5.0.0",
                    "verified": "5.2.5"
                }
            }
        ]
    },
    "url": "https://github.com/vfez1/sigil-tools",
    "manifest": "https://raw.githubusercontent.com/vfez1/sigil-tools/main/module.json",
    "download": "https://github.com/vfez1/sigil-tools/archive/refs/heads/main.zip"
}
